/* RESET */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
    Roboto, sans-serif;
  background-color: #faf7f4;
  color: #333;
}

/* LAYOUT */
.recipe-homepage {
  max-width: 1200px;
  margin: 0 auto;
  padding: 16px;
}

/* HEADER */
.header {
  margin-bottom: 24px;
}

.site-title {
  font-size: 2rem;
  font-weight: 700;
}

.site-subtitle {
  color: #777;
  margin-top: 4px;
}

/* FILTER BAR */
.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: center;
  background: #fff;
  padding: 16px;
  border-radius: 12px;
  margin-bottom: 24px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.filter-label {
  font-size: 0.8rem;
  color: #666;
}

.filter-select {
  padding: 6px 10px;
  border-radius: 8px;
  border: 1px solid #ddd;
  background: #fff;
  font-size: 0.9rem;
}

/* FAVORITES TOGGLE */
.favorites-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  font-size: 0.9rem;
}

.favorites-toggle input {
  accent-color: #e07a5f;
}

/* RANDOM BUTTON */
.random-recipe-wrapper {
  position: relative;
  margin-left: auto;
}

.random-recipe-btn {
  background: #e07a5f;
  color: #fff;
  border: none;
  padding: 10px 16px;
  border-radius: 999px;
  font-size: 0.9rem;
  cursor: pointer;
  transition: background 0.2s ease;
}

.random-recipe-btn:hover {
  background: #d56a50;
}

/* RANDOM DROPDOWN */
.random-dropdown {
  display: none;
  position: absolute;
  top: 110%;
  right: 0;
  background: #fff;
  border-radius: 12px;
  padding: 12px;
  width: 220px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.dropdown-header {
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 8px;
}

.dropdown-option {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.85rem;
  padding: 4px 0;
  cursor: pointer;
}

.dropdown-option input {
  accent-color: #e07a5f;
}

.dropdown-divider {
  height: 1px;
  background: #eee;
  margin: 8px 0;
}

/* RECIPES GRID */
.recipes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 20px;
}

/* RECIPE CARD */
.recipe-card {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 6px 14px rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  cursor: pointer;
}

